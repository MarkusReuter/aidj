# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit these (contain Spotify + Anthropic keys)
.env
.env.*
!.env.example

# secrets / credentials
*.key
*.p12
*.pfx
credentials*.json
secrets*.json

# Spotify token cache (siehe PLAN.md Phase 3 — Refresh-Token wird unter ~/.aidj-app/ gespeichert)
/.aidj-app/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE / editor
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# OS
Thumbs.db
