# Kopiere diese Datei nach .env.local und trage die Werte ein.
# .env.local ist via .gitignore ausgeschlossen — niemals committen.

# Spotify (Phase 3) — https://developer.spotify.com/dashboard
# 1. App registrieren (Web API). 2. Redirect-URI exakt wie unten eintragen.
# 3. Premium-Account als Test-User im Dashboard hinterlegen.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback

# GetSongBPM (Phase 2 — optional fürs build-library-Skript)
# Ohne Key bleibt `bpm: null` pro Track, LLM ignoriert BPM dann.
GETSONGBPM_API_KEY=

# DJ-Brain (Phase 5) — wähle EINEN der beiden Provider (oder beide → Gemini Vorrang).
# Ohne Key läuft die Heuristik-Fallback-Auswahl (BPM-Match + Tag-Overlap).

# Google Gemini — kostenloser Free-Tier, https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Anthropic / Claude — pay-per-token, https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
